										},
										"version": "v0"
									},
									"refId": "A"
								}
							}
						],
						"queryOptions": {},
						"transformations": []
					}
				},
				"description": "",
				"id": 2,
				"links": [],
				"title": "Trace Search",
				"vizConfig": {
					"group": "table",
					"kind": "VizConfig",
					"spec": {
						"fieldConfig": {
							"defaults": {
								"custom": {
									"align": "auto",
									"cellOptions": {
										"type": "auto"
									},
									"footer": {
										"reducers": []
									},
									"inspect": false
								},
								"thresholds": {
									"mode": "absolute",
									"steps": [
										{
											"color": "green",
